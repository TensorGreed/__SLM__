# ─── SLM Platform — Environment Configuration ───
# Copy this file to .env and adjust values for your environment.

# ── App ──────────────────────────────────────────────────────────────
APP_NAME="SLM Platform"
APP_VERSION="0.1.0"
DEBUG=true

# ── Auth / RBAC ──────────────────────────────────────────────────────
AUTH_ENABLED=true
# Bootstrap admin API key — set this to create admin user on startup
AUTH_BOOTSTRAP_API_KEY="sk-mock-admin-key"
AUTH_BOOTSTRAP_USERNAME="admin"
AUTH_BOOTSTRAP_ROLE="admin"
AUDIT_LOG_ENABLED=true

# API key used for local login (password field)
API_KEY="sk-mock-admin-key"
# JWT signing secret — CHANGE IN PRODUCTION
JWT_SECRET="super-secret-jwt-key-replace-in-prod"

# ── OIDC / SSO (optional) ───────────────────────────────────────────
# Uncomment and configure these to enable SSO login
# OIDC_CLIENT_ID="your-client-id"
# OIDC_CLIENT_SECRET="your-client-secret"
# OIDC_DISCOVERY_URL="https://your-idp/.well-known/openid-configuration"

# ── Database ─────────────────────────────────────────────────────────
# SQLite (default for local dev):
# Note: if using a relative sqlite path, it resolves from where uvicorn is launched.
# Using an absolute sqlite path is safer across shell locations.
DATABASE_URL="sqlite+aiosqlite:///./data/slm_platform.db"
# PostgreSQL (recommended for production):
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/slm"
DB_AUTO_CREATE=false
ALLOW_SQLITE_AUTOCREATE=true
DB_REQUIRE_ALEMBIC_HEAD=true
ALEMBIC_CONFIG_FILE="alembic.ini"

# ── Redis / Celery ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'

# ── Teacher Model (for synthetic generation) ─────────────────────────
# OpenAI-compatible API endpoint for teacher model
# TEACHER_MODEL_API_URL="http://localhost:11434/v1"
# TEACHER_MODEL_API_KEY=""
ALLOW_SYNTHETIC_DEMO_FALLBACK=false

# ── Judge Model (for LLM-as-Judge evaluation) ────────────────────────
# JUDGE_MODEL_API_URL="http://localhost:11434/v1"
# JUDGE_MODEL_API_KEY=""

# ── Ingestion ────────────────────────────────────────────────────────
ALLOW_SIMULATED_INGESTION_FALLBACK=false

# ── Training ─────────────────────────────────────────────────────────
TRAINING_BACKEND="external"          # external | simulate
ALLOW_SIMULATED_TRAINING=false
# Command template for external training script
# TRAINING_EXTERNAL_CMD='python "{backend_dir}/scripts/train.py" ...'

# ── Compression ──────────────────────────────────────────────────────
COMPRESSION_BACKEND="external"       # external | stub
ALLOW_STUB_COMPRESSION=false

# ── Process Runtime Controls ─────────────────────────────────────────
EXTERNAL_COMMAND_TIMEOUT_SECONDS=21600

# ── Domain Hook Plugins ──────────────────────────────────────────────
# JSON array of Python module paths to auto-load hook plugins at startup.
# Example:
# DOMAIN_HOOK_PLUGIN_MODULES='["app.plugins.domain_hooks.example_hooks"]'
DOMAIN_HOOK_PLUGIN_MODULES='[]'
