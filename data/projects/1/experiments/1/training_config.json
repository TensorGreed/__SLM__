{
  "base_model": "microsoft/phi-2",
  "training_mode": "sft",
  "chat_template": "llama3",
  "batch_size": 4,
  "gradient_accumulation_steps": 4,
  "learning_rate": 0.0002,
  "optimizer": "paged_adamw_8bit",
  "lr_scheduler": "cosine",
  "num_epochs": 3,
  "max_seq_length": 2048,
  "warmup_ratio": 0.03,
  "weight_decay": 0.01,
  "sequence_packing": true,
  "use_lora": true,
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "v_proj"
  ],
  "fp16": false,
  "bf16": true,
  "gradient_checkpointing": true,
  "flash_attention": true,
  "save_steps": 100,
  "eval_steps": 100,
  "early_stopping_patience": 3,
  "seed": 42
}